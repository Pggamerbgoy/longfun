{
  "name": "ai-memory-os",
  "displayName": "AI Memory OS",
  "description": "An intelligent AI memory extension for VS Code using AST and Context Caching.",
  "version": "1.0.0",
  "publisher": "NOSTEX",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pggamerbgoy/ai-memory-extension.git"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiMemory.start",
        "title": "AI Memory: Start Service"
      },
      {
        "command": "aiMemory.ask",
        "title": "AI Memory: Ask a Question"
      },
      {
        "command": "aiMemory.analyzeImpact",
        "title": "AI Memory: Analyze Impact"
      },
      {
        "command": "aiMemory.showGraph",
        "title": "AI Memory: Show Dependency Graph"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "webpack --mode production --devtool hidden-source-map",
    "webpack": "webpack --mode development"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "apache-arrow": "^18.1.0",
    "web-tree-sitter": "^0.20.8"
  }
}
